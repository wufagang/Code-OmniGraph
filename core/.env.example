# =============================================================================
# Code-OmniGraph 环境配置示例文件
# 复制此文件为 .env 并修改为您的实际配置
# =============================================================================

# =============================================================================
# Neo4j 图数据库配置
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
NEO4J_MAX_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30.0
NEO4J_ENCRYPTED=false
# 支持的类型: neo4j 默认不用配置
GRAPH_DB_TYPE=neo4j

# =============================================================================
# 向量数据库配置
# =============================================================================
# 支持的类型: qdrant, milvus
VECTOR_DB_TYPE=qdrant

# Qdrant 配置
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false
QDRANT_TIMEOUT=30.0
QDRANT_HTTPS=false
QDRANT_PREFIX=

# Milvus 配置（如果使用 Milvus）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_URI=
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DB_NAME=default
MILVUS_TOKEN=
MILVUS_SECURE=false
MILVUS_CLIENT_TIMEOUT=30.0

# =============================================================================
# 向量配置
# =============================================================================
EMBEDDING_PROVIDER      openai / gemini / ollama（默认 openai）
OPENAI_API_KEY
OPENAI_EMBEDDING_MODEL
OPENAI_API_BASE         可选，代理/Azure 地址
GEMINI_API_KEY
GEMINI_EMBEDDING_MODEL
OLLAMA_HOST             默认 localhost
OLLAMA_PORT             默认 11434
OLLAMA_EMBEDDING_MODEL  默认 nomic-embed-text
EMBEDDING_BATCH_SIZE    默认 100

# =============================================================================
# Redis 配置（用于 Celery）
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# API 配置
# =============================================================================
# FastAPI 服务地址
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# =============================================================================
# AI/LLM 配置
# =============================================================================
# OpenAI API（如果使用 OpenAI 模型）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic Claude API（如果使用 Claude）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API（已在顶层 .env 中定义）
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# 代码扫描器配置
# =============================================================================
# Joern 路径（如果使用 Joern 进行 CPG 分析）
JOERN_PATH=/opt/joern/joern-cli

# SkyWalking 配置（如果使用动态追踪）
SKYWALKING_ENDPOINT=http://localhost:12800/graphql

# =============================================================================
# 日志配置
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# =============================================================================
# 开发/调试配置
# =============================================================================
# 是否启用调试模式
DEBUG=false

# 是否启用详细日志
VERBOSE=false

# 批量操作大小
DEFAULT_BATCH_SIZE=500

# 重试配置
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY=1.0